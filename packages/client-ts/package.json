{
    "name": "@goauthentik/api",
    "version": "0.0.0",
    "description": "OpenAPI client for @goauthentik/api",
    "author": "OpenAPI-Generator",
    "repository": {
        "type": "git",
        "url": "https://github.com/goauthentik/authentik.git"
    },
    "scripts": {
        "clean": "tsc -b --clean tsconfig.json tsconfig.esm.json",
