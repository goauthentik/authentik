    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "devDependencies": {
        "@goauthentik/prettier-config": "^3.5.0",
        "prettier": "^3.8.1",
        "typescript": "^4.0 || ^5.0"
