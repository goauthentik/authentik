# The shipped hexworld.pmtiles archive is checked in (see README). Everything
# else generated under tiles/ — intermediate cuts, glyphs pulled from the
# public CDN, generator scratch — stays local.
/tiles/*.pmtiles
!/tiles/hexworld.pmtiles
/tiles/*.mbtiles
/tiles/fonts/
/tiles/*.geojsonl
/tiles/*.geojson
/out/
/node_modules/
*.tsbuildinfo
