{
    "name": "@goauthentik/geo",
    "version": "1.0.0",
    "description": "MapLibre-based map component and Protomaps tooling for authentik",
    "license": "MIT",
    "private": true,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/goauthentik/authentik.git",
        "directory": "packages/geo"
    },
    "type": "module",
    "main": "./out/index.js",
    "types": "./out/index.d.ts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./out/index.d.ts",
            "import": "./out/index.js"
        },
        "./style": {
            "types": "./out/style.d.ts",
            "import": "./out/style.js"
        },
        "./components/ak-map": {
            "types": "./out/components/ak-map.d.ts",
            "import": "./out/components/ak-map.js"
        }
    },
    "scripts": {
        "build": "tsc -p .",
        "watch": "tsc -p . --watch",
        "lint": "eslint --fix .",
        "lint-check": "eslint --max-warnings 0 .",
        "prettier": "prettier --write .",
        "prettier-check": "prettier --check ."
    },
    "dependencies": {
        "@protomaps/basemaps": "^5.7.2",
        "lit": "^3.3.2",
        "maplibre-gl": "^5.10.0",
        "pmtiles": "^4.4.1"
    },
    "devDependencies": {
        "@goauthentik/prettier-config": "workspace:*",
        "@goauthentik/tsconfig": "workspace:*",
        "@types/node": "catalog:",
        "typescript": "catalog:"
    },
    "peerDependencies": {
        "lit": "^3.3.2",
        "maplibre-gl": "^5.10.0"
    },
    "files": [
        "out/**/*",
        "src/**/*"
    ],
    "engines": {
        "node": ">=24"
    },
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": ">=24",
            "onFail": "warn"
        },
        "packageManager": {
            "name": "pnpm",
            "version": ">=11.5.1",
            "onFail": "warn"
        }
    },
    "prettier": "@goauthentik/prettier-config"
}
