{
    "name": "@goauthentik/logger-js",
    "version": "2.0.1",
    "description": "Pino-based logger for authentik",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/goauthentik/authentik.git",
        "directory": "packages/logger-js"
    },
    "scripts": {
        "build": "tsc -p .",
        "lint": "eslint --fix .",
        "lint-check": "eslint --max-warnings 0 .",
        "prettier": "prettier --write .",
        "prettier-check": "prettier --check .",
        "watch": "tsc -p . --watch"
    },
    "type": "module",
    "types": "./out/index.d.ts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./out/index.d.ts",
            "node": "./lib/node.js",
            "browser": "./index.js",
            "import": "./index.js"
        }
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@goauthentik/prettier-config": "link:../prettier-config",
        "@goauthentik/tsconfig": "link:../tsconfig",
        "@types/node": "^26.1.1",
        "eslint": "catalog:",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "prettier": "3.8.3",
        "prettier-plugin-packagejson": "catalog:",
        "typescript": "catalog:",
        "typescript-eslint": "^8.62.1"
    },
    "peerDependencies": {
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.2"
    },
    "files": [
        "./index.js",
        "lib/**/*",
        "out/**/*"
    ],
    "engines": {
        "node": ">=24"
    },
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": ">=24",
            "onFail": "ignore"
        },
        "packageManager": {
            "name": "pnpm",
            "version": ">=11.5.1",
            "onFail": "ignore"
        }
    },
    "prettier": "@goauthentik/prettier-config",
    "peerDependenciesMeta": {
        "pino": {
            "optional": true
        },
        "pino-pretty": {
            "optional": true
        }
    },
    "publishConfig": {
        "access": "public"
    }
}
