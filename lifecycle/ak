#!/usr/bin/env bash

set -e -o pipefail

MODE_FILE="$TMPDIR/authentik-mode"

function log {
    printf '{"event": "%s", "level": "info", "logger": "bootstrap"}\n' "$@" >&2
}

function wait_for_db {
    python -m lifecycle.wait_for_db
    log "Bootstrap completed"
}

function run_authentik {
    case "$1" in
    server)
        shift 1
        echo -n server >"$MODE_FILE"
        if [[ -x "$(command -v authentik-server)" ]]; then
            echo authentik-server "$@"
        else
            echo go run ./cmd/server "$@"
        fi
        ;;
    healthcheck)
        if [[ -x "$(command -v authentik)" ]]; then
            echo authentik "$@"
        else
            echo cargo run -- "$@"
        fi
        ;;
    allinone | worker)
        if [[ -x "$(command -v authentik)" ]]; then
            echo authentik "$@"
        else
            echo cargo run -- "$@"
        fi
        ;;
    manage)
        shift 1
        echo python -m manage "$@"
        ;;
    *)
        echo "$@"
        ;;
    esac
}

function prepare_media_dir {
    if [[ ! -w /data ]]; then
        log "Unable to prepare media directory because /data is not writable; continuing"
        return 0
    fi

    local legacy_media_entry
    legacy_media_entry=""
    if [[ -d /media && ! -L /media ]]; then
        legacy_media_entry="$(find /media -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null || true)"
    fi

    if [[ -n "$legacy_media_entry" ]]; then
        if [[ -L /data/media ]]; then
            if ! rm -- /data/media || ! ln -s /media /data/media; then
                log "Unable to link /data/media to the legacy /media directory; continuing"
            fi
        elif [[ ! -e /data/media ]]; then
            if ! ln -s /media /data/media; then
                log "Unable to link /data/media to the legacy /media directory; continuing"
            fi
        elif [[ -d /data/media ]]; then
            local current_media_entry
            current_media_entry="$(find /data/media -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null || true)"
            if [[ -n "$current_media_entry" ]]; then
                log "WARNING: /data/media contains data; preserving it instead of linking to legacy /media"
                return 0
            fi
            if ! rmdir -- /data/media || ! ln -s /media /data/media; then
                log "Unable to replace empty /data/media with a link to legacy /media; continuing"
            fi
        else
            log "WARNING: /data/media is not a directory or symlink; preserving it"
        fi
        return 0
    fi

    if [[ -L /data/media ]]; then
        local media_target
        local media_staging
        media_target="$(readlink -f /data/media || true)"
        if [[ "$media_target" != "/media" ]]; then
            return 0
        fi
        if ! media_staging="$(mktemp -d /data/media.XXXXXX)"; then
            log "Unable to create media staging directory; continuing"
            return 0
        fi
        if [[ -d "$media_target" ]] && ! cp -a "$media_target"/. "$media_staging"/; then
            log "Unable to copy legacy media into /data; continuing"
            rm -rf -- "$media_staging" || true
            return 0
        fi
        if ! rm -- /data/media; then
            log "Unable to replace the legacy /data/media symlink; continuing"
            rm -rf -- "$media_staging" || true
            return 0
        fi
        if ! mv "$media_staging" /data/media; then
            log "Unable to install the prepared media directory; continuing"
        fi
    else
        if ! mkdir -p /data/media; then
            log "Unable to create /data/media; continuing"
        fi
    fi
    return 0
}

function check_if_root_and_run {
    prepare_media_dir || true
    if [[ $EUID -ne 0 ]]; then
        log "Not running as root, disabling permission fixes"
        exec $(run_authentik "$@")
        return
    fi
    SOCKET="/var/run/docker.sock"
    if [[ -e "$SOCKET" ]]; then
        # Get group ID of the docker socket, so we can create a matching group and
        # add ourselves to it
        DOCKER_GID="$(stat -c "%g" "${SOCKET}")"
        # Ensure group for the id exists
        getent group "${DOCKER_GID}" || groupadd -f -g "${DOCKER_GID}" docker
        usermod -a -G "${DOCKER_GID}" authentik
    fi
    # Fix permissions of certs and media
    chown -R authentik:authentik /data /certs "${PROMETHEUS_MULTIPROC_DIR}"
    chmod ug+rwx /data
    chmod ug+rx /certs
    exec setpriv --reuid authentik --regid authentik --init-groups -- env HOME=/authentik $(run_authentik "$@")
}

function prepare_debug {
    # Only attempt to install debug dependencies if we're running in a container
    if [ ! -d /ak-root ]; then
        return
    fi
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends krb5-kdc krb5-user krb5-admin-server libkrb5-dev gcc
    source "${VENV_PATH}/bin/activate"
    uv sync --active --locked
    touch /unittest.xml
    chown authentik:authentik /unittest.xml
}

if [[ -z "${PROMETHEUS_MULTIPROC_DIR}" ]]; then
    export PROMETHEUS_MULTIPROC_DIR="${TMPDIR:-/tmp}/authentik_prometheus_tmp"
fi
mkdir -p "${PROMETHEUS_MULTIPROC_DIR}"

if [[ "$(python -m authentik.lib.config debugger 2>/dev/null)" == "True" ]]; then
    prepare_debug
fi

if [[ "$1" == "bash" ]]; then
    exec /usr/bin/env -S bash "$@"
elif [[ "$1" == "dump_config" ]]; then
    shift 1
    exec python -m authentik.lib.config "$@"
elif [[ "$1" == "debug" ]]; then
    exec sleep infinity
elif [[ "$1" == "test-all" ]]; then
    wait_for_db
    prepare_debug
    chmod 777 /root
    check_if_root_and_run manage test authentik
elif [[ "$1" == "allinone" ]] || [[ "$1" == "server" ]] || [[ "$1" == "worker" ]]; then
    wait_for_db
    check_if_root_and_run "$@"
elif [[ "$1" == "healthcheck" ]]; then
    check_if_root_and_run "$@" "$(cat "$MODE_FILE")"
else
    wait_for_db
    exec python -m manage "$@"
fi
