#: authentik/admin/files/api.py
#, python-brace-format
msgid "File size ({file.size}B) exceeds maximum allowed "
msgstr "Veličina datoteke ({file.size}B) prelazi maksimalno dopuštenu "

#: authentik/admin/files/validation.py
msgid "File name cannot be empty"
msgstr "Naziv datoteke ne može biti prazan"

#: authentik/admin/files/validation.py
#, python-format
msgid ""
"File name can only contain letters (a-z, A-Z), numbers (0-9), dots (.), "
"hyphens (-), underscores (_), forward slashes (/), and the placeholder "
"%(theme)s for theme-specific files"
msgstr ""
"Naziv datoteke može sadržavati samo slova (a-z, A-Z), brojeve (0-9), točke "
"(.), crtice (-) i podcrtave (_), kosu crtu (/) te rezerviranu oznaku "
"%(theme)s za datoteke specifične za temu"

#: authentik/admin/files/validation.py
msgid "File name cannot contain duplicate /"
msgstr "Naziv datoteke ne može sadržavati duplikate /"

#: authentik/admin/files/validation.py
msgid "Absolute paths are not allowed"
msgstr "Apsolutne putanje nisu dopuštene"

#: authentik/admin/files/validation.py
msgid "Parent directory references ('..') are not allowed"
msgstr "Referencije na roditeljski direktorij ('..') nisu dopuštene"

#: authentik/admin/files/validation.py
msgid "Paths cannot start with '.'"
msgstr "Putanje ne mogu započeti s '.'."

#: authentik/admin/files/validation.py
#, python-brace-format
msgid "File name too long (max {MAX_FILE_NAME_LENGTH} characters)"
msgstr "Naziv datoteke predug (max {MAX_FILE_NAME_LENGTH} znakova)"

#: authentik/admin/files/validation.py
#, python-brace-format
msgid "Path component too long (max {MAX_PATH_COMPONENT_LENGTH} characters)"
msgstr ""
"Kompoenta putanje je preduga (max {MAX_PATH_COMPONENT_LENGTH} znakova)"

